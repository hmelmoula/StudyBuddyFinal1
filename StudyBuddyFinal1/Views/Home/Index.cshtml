@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to StudyBuddy</h1>

    <p class="lead mt-3">
        Organise your courses, manage your tasks, and stay on track with your studies.
    </p>

    <div class="mt-4">
        <a class="btn btn-primary btn-lg me-2" asp-controller="Courses" asp-action="Index">
            View Courses
        </a>

        <a class="btn btn-success btn-lg" asp-controller="TaskItems" asp-action="Index">
            View Tasks
        </a>
    </div>
</div>